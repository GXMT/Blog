---
import {
  SITE_TITLE,
  SITE_URL,
  AUTHOR,
  LOCALE,
  ADSENSE_CLIENT,
  NAVER_SITE_VERIFICATION,
  GOOGLE_SITE_VERIFICATION,
} from '../consts.mjs';

interface Props {
  title: string;
  description: string;
  /** OG 이미지 절대/상대 경로 (선택) */
  image?: string;
  /** 'website' | 'article' */
  type?: 'website' | 'article';
  publishedTime?: Date;
  modifiedTime?: Date;
  tags?: string[];
}

const {
  title,
  description,
  image = '/og-default.png',
  type = 'website',
  publishedTime,
  modifiedTime,
  tags = [],
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site ?? SITE_URL);
const imageURL = new URL(image, Astro.site ?? SITE_URL);

// 구조화 데이터: 글이면 BlogPosting, 그 외 WebSite
const jsonLd =
  type === 'article'
    ? {
        '@context': 'https://schema.org',
        '@type': 'BlogPosting',
        headline: title,
        description,
        image: imageURL.toString(),
        author: { '@type': 'Person', name: AUTHOR },
        publisher: { '@type': 'Organization', name: SITE_TITLE },
        datePublished: publishedTime?.toISOString(),
        dateModified: (modifiedTime ?? publishedTime)?.toISOString(),
        mainEntityOfPage: { '@type': 'WebPage', '@id': canonicalURL.toString() },
        keywords: tags.join(', '),
      }
    : {
        '@context': 'https://schema.org',
        '@type': 'WebSite',
        name: SITE_TITLE,
        url: SITE_URL,
      };
---

<meta charset="utf-8" />
<meta name="viewport" content="width=device-width,initial-scale=1" />
<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
<meta name="generator" content={Astro.generator} />

<!-- Canonical -->
<link rel="canonical" href={canonicalURL} />

<!-- Primary Meta -->
<title>{title}</title>
<meta name="title" content={title} />
<meta name="description" content={description} />
<meta name="author" content={AUTHOR} />

<!-- 검색엔진 소유확인 (값이 있을 때만) -->
{GOOGLE_SITE_VERIFICATION && (
  <meta name="google-site-verification" content={GOOGLE_SITE_VERIFICATION} />
)}
{NAVER_SITE_VERIFICATION && (
  <meta name="naver-site-verification" content={NAVER_SITE_VERIFICATION} />
)}

<!-- Open Graph (카카오톡/네이버/페이스북 공유 미리보기의 핵심) -->
<meta property="og:type" content={type} />
<meta property="og:url" content={canonicalURL} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:image" content={imageURL} />
<meta property="og:site_name" content={SITE_TITLE} />
<meta property="og:locale" content={LOCALE} />
{publishedTime && (
  <meta property="article:published_time" content={publishedTime.toISOString()} />
)}
{modifiedTime && (
  <meta property="article:modified_time" content={modifiedTime.toISOString()} />
)}

<!-- Twitter -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={imageURL} />

<!-- RSS 자동발견 -->
<link
  rel="alternate"
  type="application/rss+xml"
  title={SITE_TITLE}
  href={new URL('rss.xml', Astro.site ?? SITE_URL)}
/>

<!-- 구조화 데이터 -->
<script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

<!--
  Google AdSense (Auto Ads + 승인 심사용).
  AdSense 크롤러가 감지할 수 있도록 표준 async 스니펫을 head에 그대로 삽입.
  async라 렌더를 막지 않습니다. ADSENSE_CLIENT가 비어 있으면 미삽입.
-->
{ADSENSE_CLIENT && (
  <script
    async
    src={`https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=${ADSENSE_CLIENT}`}
    crossorigin="anonymous"
  ></script>
)}
